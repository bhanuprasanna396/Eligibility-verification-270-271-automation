# ── HOW TO USE ────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Generate an encryption key and paste it below:
#      python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 3. Leave everything else as-is for local development (Docker defaults match).

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# HIPAA PHI encryption — app will NOT start without this
PHI_ENCRYPTION_KEY=PASTE_YOUR_GENERATED_KEY_HERE

# PostgreSQL — matches docker-compose.yml defaults
POSTGRES_USER=eligibility_user
POSTGRES_PASSWORD=eligibility_pass
POSTGRES_DB=eligibility_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis — matches docker-compose.yml defaults
REDIS_URL=redis://localhost:6379/0

# ── OPTIONAL — only needed for real clearinghouse (not the mock) ──────────────

CLEARINGHOUSE_BASE_URL=https://sandbox.availity.com
CLEARINGHOUSE_CLIENT_ID=your_client_id_here
CLEARINGHOUSE_CLIENT_SECRET=your_client_secret_here

# Your clinic's EDI identifiers (from your clearinghouse account)
CLINIC_NPI=1234567890
CLINIC_TAX_ID=123456789
CLINIC_EDI_ID=YOURCLINIC
CLEARINGHOUSE_EDI_ID=CLEARINGHOUSE

# Days before appointment to auto-run eligibility check
ELIGIBILITY_CHECK_DAYS_BEFORE=3

# App
APP_ENV=development
SECRET_KEY=change-this-to-any-random-string-in-production
