# Copy this file to .env and fill in real values.
# Generate PHI_ENCRYPTION_KEY with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── HIPAA — PHI field encryption (REQUIRED) ───────────────────────────────
PHI_ENCRYPTION_KEY=bq2PUj5HOoCwS0shVGPqcszEZPkqTMq94mmP4vavAhU=

# Database
POSTGRES_USER=eligibility_user
POSTGRES_PASSWORD=eligibility_pass
POSTGRES_DB=eligibility_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Clearinghouse (fill in when connecting to real clearinghouse)
CLEARINGHOUSE_BASE_URL=https://sandbox.availity.com
CLEARINGHOUSE_CLIENT_ID=your_client_id_here
CLEARINGHOUSE_CLIENT_SECRET=your_client_secret_here

# Your clinic's EDI identifiers
CLINIC_NPI=1234567890
CLINIC_TAX_ID=123456789
CLINIC_EDI_ID=YOURCLINIC
CLEARINGHOUSE_EDI_ID=CLEARINGHOUSE

# How many days before appointment to run eligibility check
ELIGIBILITY_CHECK_DAYS_BEFORE=3

# App
APP_ENV=development
SECRET_KEY=change-this-in-production
